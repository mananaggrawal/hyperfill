# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/

# ── Company data (confidential — never pushed to git) ────────────────────────
# company/ is a flat drop zone — user files only, nothing tracked except .gitkeep.
company/*
!company/.gitkeep

# ── Claude's internal memory (stays local only) ───────────────────────────────
.rfp-kit/*
!.rfp-kit/.gitkeep

# ── Bid work (stays local / on Drive) ────────────────────────────────────────
bids/*
!bids/README.md
!bids/_template/
!bids/_template/**
