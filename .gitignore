# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/

# ── Company data (confidential — never pushed to git) ────────────────────────
# company/ is a flat drop zone — user files only, nothing tracked except .gitkeep.
company/*
!company/.gitkeep

# ── Claude's internal memory + working files (stays local only) ──────────────
.rfp-kit/*
!.rfp-kit/.gitkeep

# ── Bid folders — only the _template scaffold is tracked ─────────────────────
bids/*
!bids/_template/
!bids/_template/source/
!bids/_template/source/.gitkeep
!bids/_template/outputs/
!bids/_template/outputs/submission/
!bids/_template/outputs/submission/.gitkeep

# ── Internal / developer files (hidden from user) ────────────────────────────
docs/
examples/
setup.sh
