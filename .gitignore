# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/

# ── Company data (confidential — never pushed to git) ────────────────────────
# All your certificates, financials, letterhead, signature, and narrative docs
# live only on your local machine / Google Drive. Never in git.
company/company-info.json
company/about/*
company/documents/*
company/experience/*
company/letterhead/*
company/signature/*

# Keep folder README stubs so structure survives a fresh clone
!**/README.md
!**/.gitkeep

# ── Bid work (stays local / on Drive) ────────────────────────────────────────
bids/*
!bids/README.md
!bids/_template/
!bids/_template/**
