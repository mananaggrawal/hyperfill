.DS_Store
__pycache__/
*.pyc
*.egg-info/
build/
dist/
.venv/
venv/
.idea/
.vscode/

# ============================================================================
# Your private content is kept OUT of git by default, so you never push your
# letterhead, signature, company documents, or work-in-progress bids by accident.
# Folder structure is preserved via README.md / .gitkeep files.
# If you keep a PRIVATE repo and WANT your files versioned, delete the relevant
# lines below.
# ============================================================================

# Your filled-in details (contains names, contacts) — uncomment to keep out of git:
# company/company-info.json

# Letterhead and (especially) the signature/stamp image
company/letterhead/*
company/signature/*

# Documents, experience proofs, and narrative material you add
company/documents/*
company/experience/*
company/about/*

# Always keep the placeholders so the structure survives a clone
!**/README.md
!**/.gitkeep

# Per-bid work (keep the template and the bids README)
bids/*
!bids/_template/
!bids/README.md
