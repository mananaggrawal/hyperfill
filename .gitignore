# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/

# ── Company data (confidential — never pushed to git) ────────────────────────
# Everything inside company/ is private. Only README stubs are tracked.
company/*
!company/README.md
!company/*/README.md
!**/.gitkeep

# ── Bid work (stays local / on Drive) ────────────────────────────────────────
bids/*
!bids/README.md
!bids/_template/
!bids/_template/**
